#!/usr/bin/env bash

. ./common
latest_year=$(gly)

fname="$1"
name=$(basename -s .toml $fname)
year="${name##*_}"

suffix="_$year"
if [[ "$year" == "$latest_year" ]]; then suffix=""; fi

awk -v suffix="$suffix" -v latest_year="$latest_year" -v year="$year" '
BEGIN{
    print "! SPDX-License-Identifier: MIT"
    print ""
    print "!======================================================================="
    if(suffix==""){
        print "! MODULE: CODATA_CONSTANTS_"year
    }
    else{
        print "! MODULE: CODATA_CONSTANTS"suffix
    }
    print "!======================================================================="
    print "!{{{1"
    print "module codata__constants_"year
    print "!! Codata Constants - Autogenerated"
    print "use stdlib_kinds, only: dp, int32"
    print "use codata__constants_type"
    print "implicit none(type,external)"
    print "private"
    print ""
    print "integer(int32), parameter, public :: YEAR"suffix" = "year" !! Year of release."
    print ""
    print ""
    print ""
    print "!-----------------------------------------------------------------------"
    print "! CONSTANTS"
    print "!-----------------------------------------------------------------------"
    print "!{{{2"

    i=0

}
/^\[.*\]/{
    gsub(/\[/,"")
    gsub(/\]/,"")
    var=$0 suffix
    i++
    vars[i]=var
    print "type(codata_constant_type), parameter, public :: "var" = &"
}
/^name/{
    split($0, x, " = ")
    print "codata_constant_type("x[2]", &"
    name = x[2]
    gsub(/"/,"",name)
}
/^value/{
    gsub(/"/, "")
    split($0, x, " = ")
    printf "%s", x[2]"_dp, "
}
/^uncertainty/{
    gsub(/"/, "")
    split($0, x, " = ")
    print x[2]"_dp, &"
}
/^unit/{
    split($0, x, " = ")
    print x[2]") !! "name
}
NF==0{
    print ""
}
END{
    print "!-----------------------------------------------------------------------"
    print "!}}}"
    print "!END FOR STDLIB"
    print ""
    print ""
    print "!-----------------------------------------------------------------------"
    print "! ARRAY OF CONSTANTS"
    print "!-----------------------------------------------------------------------"
    print "!{{{2"
    print "type(codata_constant_type), target, public :: cc"suffix"("i") = &" 
    for (j in vars){
        if(j==1){
            printf "%s", "["
            print vars[j]", &"
        }
        else if(j==i){
            print vars[j]" &"
        }
        else{
            print vars[j]", &"
        }

    }
    print "]"
    print "!-----------------------------------------------------------------------"
    print "!}}}"
    print "end module codata__constants_"year
}
' $1
