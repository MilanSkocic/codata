#!/usr/bin/env bash

. ./common
latest_year=$(gly)

fname="$1"
name=$(basename -s .toml $fname)
year="${name##*_}"

suffix="_$year"
if [[ "$year" == "$latest_year" ]]; then suffix=""; fi

awk -v suffix="$suffix" -v year="$year" '
BEGIN{
    print ".SH CODATA " year
    print ".PP"
    print "List of available constants:"
    print ".\\\"{{{"
}
/^\[.*\]/{
    gsub(/\[/,"")
    gsub(/\]/,"")
    print ".IP \\(bu "
    print $0, suffix
}
END{print ".\\\"}}}"}
' $1
