#!/usr/bin/env bash

years=()
for i in src/*;do 
    b=$(basename -s .txt $i)
    b=${b##*_}
    years+=($b)
done; 
latest_year=$(printf "%s\n" ${years[@]} | sort -n | tail -1)

fname="$1"
name=$(basename -s .toml $fname)
year="${name##*_}"

suffix="_$year"
if [[ "$year" == "$latest_year" ]]; then suffix=""; fi

awk -v suffix="$suffix" '
BEGIN{
    print "  List of available constants:"
}
/^\[.*\]/{
    gsub(/\[/,"")
    gsub(/\]/,"")
    printf "%s%s%s\n", "  o ", $0, suffix
}
' $1
